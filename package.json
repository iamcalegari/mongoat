{
  "name": "@iamcalegari/mongoat",
  "version": "1.0.34-alpha",
  "description": "A ligthweight ODM library for MongoDB",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamcalegari/mongoat.git"
  },
  "author": "iamcalegari <iamcalegari20@gmail.com>",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=16.20.1"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && tsc-alias",
    "example": "ts-node --",
    "prebuild": "rimraf ./lib"
  },
  "dependencies": {
    "bson": "7.0.0",
    "json-schema": "0.4.0",
    "mongodb": "7.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "eslint": "9.39.2",
    "prettier": "3.7.4",
    "rimraf": "6.1.2",
    "ts-jest": "29.4.6",
    "ts-node-dev": "2.0.0",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-cached-transpile": "0.0.6",
    "typescript-eslint": "8.50.0"
  },
  "files": [
    "lib",
    "src",
    "tsconfig.json"
  ],
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./database": {
      "types": "./lib/database/index.d.ts",
      "default": "./lib/database/index.js"
    },
    "./model": {
      "types": "./lib/model/index.d.ts",
      "default": "./lib/model/index.js"
    },
    "./utils": {
      "types": "./lib/utils/index.d.ts",
      "default": "./lib/utils/index.js"
    },
    "./types": {
      "types": "./lib/types/index.d.ts",
      "default": "./lib/types/index.js"
    }
  }
}
