{
  "name": "@iamcalegari/mongoat",
  "version": "1.0.34-alpha",
  "description": "A ligthweight ODM library for MongoDB",
  "homepage": "https://iamcalegari.github.io/mongoat/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamcalegari/mongoat.git"
  },
  "author": "iamcalegari <iamcalegari20@gmail.com>",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsdown --config-loader native",
    "check:package": "npm pack --dry-run && npx publint && npx @arethetypeswrong/cli --pack .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "example": "tsx",
    "lint": "eslint .",
    "prebuild": "rimraf ./lib",
    "predocs:dev": "typedoc",
    "predocs:build": "typedoc",
    "release": "changeset publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bson": "7.0.0",
    "mongodb": "7.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "^9.39.4",
    "@testcontainers/mongodb": "^12.0.4",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "9.39.2",
    "prettier": "3.7.4",
    "publint": "^0.3.21",
    "rimraf": "6.1.2",
    "testcontainers": "^12.0.4",
    "tsdown": "^0.22.3",
    "tslib": "2.8.1",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10"
  },
  "files": [
    "lib"
  ],
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    }
  }
}
